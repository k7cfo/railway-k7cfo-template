{
  "name": "{{ project_slug }}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "doctor": "node scripts/doctor.mjs",
    "dev": "concurrently -k -n api,web -c cyan,magenta \"pnpm dev:server\" \"pnpm dev:web\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "tsup src/server.ts --format esm --platform node --out-dir dist --clean && pnpm build:web",
    "build:web": "vite build --config web/vite.config.ts",
    "start": "node dist/server.js",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit && tsc -p web/tsconfig.app.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "deploy:check": "node scripts/deploy-check.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@aws-sdk/client-s3": "^3.900.0",
    "@better-auth/stripe": "^1.6.5",
    "@fontsource-variable/archivo": "^5.2.8",
    "@fontsource-variable/doto": "^5.2.10",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/archivo-narrow": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@hono/node-server": "^1.19.5",
    "@paper-design/shaders-react": "^0.0.77",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@shadcn/react": "^0.2.0",
    "@tanstack/react-query": "^5.90.0",
    "@ai-sdk/react": "^3.0.0",
    "ai": "^6.0.0",
    "better-auth": "^1.6.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.0",
    "drizzle-orm": "^0.45.0",
    "hono": "^4.12.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.0.0",
    "pg": "^8.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.0",
    "radix-ui": "^1.4.3",
    "resend": "^6.0.0",
    "sonner": "^2.0.0",
    "stripe": "^22.0.0",
    "tsx": "^4.20.0",
