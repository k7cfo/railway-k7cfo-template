import { useState } from "react"
import { useMutation } from "@tanstack/react-query"
import { Link, useNavigate, useSearchParams } from "react-router"
import { KeyRound, Loader, TriangleAlert } from "lucide-react"
import { toast } from "sonner"

import { authClient } from "@/lib/auth-client"
import { AuthShell } from "@/components/auth-shell"
import { Button } from "@/components/ui/button"
import {
  Field,
  FieldDescription,
  FieldError,
  FieldGroup,
  FieldLabel,
} from "@/components/ui/field"
import { Input } from "@/components/ui/input"

export function ResetPassword() {
  const navigate = useNavigate()
  const [searchParams] = useSearchParams()
  const [password, setPassword] = useState("")

  // Better Auth's reset link lands here with either ?token=... (valid) or
  // ?error=INVALID_TOKEN (expired/tampered). No token at all means the page
  // was opened directly.
  const token = searchParams.get("token")
  const linkError = searchParams.get("error")

  const resetPassword = useMutation({
    mutationFn: (input: { newPassword: string; token: string }) =>
      authClient.resetPassword(input),
    onSuccess: () => {
      toast.success("Password updated. You can sign in now.")
      navigate("/login", { replace: true })
    },
  })

  function onSubmit(event: React.FormEvent<HTMLFormElement>) {
    event.preventDefault()
    if (!token) return
    resetPassword.mutate({ newPassword: password, token })
  }

  // No usable token: the link is expired, malformed, or was opened directly.
  if (!token || linkError) {
    return (
      <AuthShell
        appTitle="{{ app_title }}"
        title="Reset link invalid"
        description="This password reset link is invalid or has expired."
        footer={
          <>
            Back to{" "}
            <Link
              to="/login"
              className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
            >
              Sign in
            </Link>
          </>
        }
      >
        <div className="flex flex-col items-center gap-4 py-4 text-center">
          <TriangleAlert className="size-10 text-destructive" />
          <p className="m-0 text-sm leading-relaxed text-[var(--fg-2)]">
            Reset links expire after one hour and can only be used once.{" "}
            <Link
              to="/forgot-password"
              className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
            >
              Request a new one
            </Link>
            .
          </p>
        </div>
      </AuthShell>
    )
  }

  const error =
    resetPassword.error instanceof Error ? resetPassword.error.message : null

  return (
    <AuthShell
      appTitle="{{ app_title }}"
      title="Choose a new password"
      description="Enter a new password for your account."
      footer={
        <>
          Back to{" "}
          <Link
            to="/login"
            className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
          >
            Sign in
          </Link>
        </>
      }
    >
      <form onSubmit={onSubmit}>
        <FieldGroup>
          <Field data-invalid={error ? true : undefined}>
            <FieldLabel htmlFor="reset-password">New password</FieldLabel>
            <Input
              id="reset-password"
              type="password"
              autoComplete="new-password"
              minLength={8}
              required
              value={password}
              onChange={(e) => setPassword(e.target.value)}
              aria-invalid={error ? true : undefined}
            />
            <FieldDescription>At least 8 characters.</FieldDescription>
            <FieldError>{error}</FieldError>
          </Field>
          <Button
            type="submit"
            disabled={resetPassword.isPending}
            className="w-full"
          >
            {resetPassword.isPending ? (
              <Loader className="animate-spin" />
            ) : (
              <KeyRound />
            )}
            Update password <span aria-hidden>&rarr;</span>
          </Button>
        </FieldGroup>
      </form>
    </AuthShell>
  )
}
