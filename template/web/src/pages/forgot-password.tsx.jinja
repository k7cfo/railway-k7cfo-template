import { useState } from "react"
import { useMutation } from "@tanstack/react-query"
import { Link } from "react-router"
import { Loader, MailCheck, Send } from "lucide-react"

import { authClient } from "@/lib/auth-client"
import { AuthShell } from "@/components/auth-shell"
import { Button } from "@/components/ui/button"
import { Field, FieldGroup, FieldLabel } from "@/components/ui/field"
import { Input } from "@/components/ui/input"

export function ForgotPassword() {
  const [email, setEmail] = useState("")

  const requestReset = useMutation({
    mutationFn: (input: { email: string }) =>
      authClient.requestPasswordReset({
        email: input.email,
        // Better Auth appends ?token=... (or ?error=INVALID_TOKEN) to this path
        // and the reset page reads it back off the URL.
        redirectTo: "/reset-password",
      }),
  })

  function onSubmit(event: React.FormEvent<HTMLFormElement>) {
    event.preventDefault()
    requestReset.mutate({ email })
  }

  // The API answers identically whether or not the address is on file
  // (anti-enumeration), so success just means "we accepted the request".
  if (requestReset.isSuccess) {
    return (
      <AuthShell
        appTitle="{{ app_title }}"
        title="Check your email"
        description="If an account exists for that address, a password reset link is on its way."
        footer={
          <>
            Back to{" "}
            <Link
              to="/login"
              className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
            >
              Sign in
            </Link>
          </>
        }
      >
        <div className="flex flex-col items-center gap-4 py-4 text-center">
          <MailCheck className="size-10 text-[var(--bf-orange)]" />
          <p className="m-0 text-sm leading-relaxed text-[var(--fg-2)]">
            We sent a reset link to <strong>{email}</strong>. The link expires in
            one hour. Didn&rsquo;t get it? Check your spam folder or{" "}
            <button
              type="button"
              onClick={() => requestReset.reset()}
              className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
            >
              try again
            </button>
            .
          </p>
        </div>
      </AuthShell>
    )
  }

  return (
    <AuthShell
      appTitle="{{ app_title }}"
      title="Forgot your password?"
      description="Enter your email and we'll send you a link to reset it."
      footer={
        <>
          Remembered it?{" "}
          <Link
            to="/login"
            className="text-[var(--bf-orange)] underline-offset-4 hover:underline"
          >
            Sign in
          </Link>
        </>
      }
    >
      <form onSubmit={onSubmit}>
        <FieldGroup>
          <Field>
            <FieldLabel htmlFor="forgot-email">Email</FieldLabel>
            <Input
              id="forgot-email"
              type="email"
              autoComplete="email"
              required
              value={email}
              onChange={(e) => setEmail(e.target.value)}
            />
          </Field>
          <Button
            type="submit"
            disabled={requestReset.isPending}
            className="w-full"
          >
            {requestReset.isPending ? (
              <Loader className="animate-spin" />
            ) : (
              <Send />
            )}
            Send reset link <span aria-hidden>&rarr;</span>
          </Button>
        </FieldGroup>
      </form>
    </AuthShell>
  )
}
