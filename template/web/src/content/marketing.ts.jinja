// ─── MARKETING CONTENT — EDIT THIS FILE FIRST ────────────────────────────────
// Every section of the landing page reads from this object. To make the page
// yours: rewrite the copy here, top to bottom, before touching any component.
// Sections hide themselves when their content is empty (e.g. an empty
// `testimonials` array renders nothing — never ship fake social proof).
//
// Copy guidance (CRO):
// - `hero.headline` is the value proposition, not your brand name — the visitor
//   should learn what they GET, in their own vocabulary. Outcome > mechanism.
// - One primary CTA, repeated (hero → pricing → final band). Everything else
//   is secondary.
// - `benefits` lead with the outcome; the mono `caption` carries the garnish.
// - Keep a risk-reversal line ("free tier · no credit card") beside every CTA.
// - Speak to END USERS. Implementation details (the stack, the repo, deploy
//   commands) belong in the README and CLAUDE.md, not on this page.
// ─────────────────────────────────────────────────────────────────────────────

export type Cta = { label: string; to: string }

export type MarketingContent = {
  hero: {
    /** Mono instrument label, top-left (decorative). */
    eyebrow?: string
    /** Mono label, top-right (decorative). */
    eyebrowMeta?: string
    /** The mega-type value proposition. Short lines, outcome-first. */
    headline: string
    /** One or two sentences under the headline. */
    subhead: string
    /** Optional supporting paragraph. */
    body?: string
    cta: Cta
    /** Secondary, low-emphasis link (e.g. anchor to pricing). */
    secondaryCta?: Cta
    /** Trust line rendered beside the CTA. */
    riskReversal?: string
    /** Mono metadata segments that scramble in. Decorative texture. */
    metadata?: string[]
    /** Hero proof artifact. "image" renders a product screenshot in a
     * hard-edged instrument frame — drop the file in web/public and point
     * `src` at it (e.g. "/proof.png"). "none" hides the slot. */
    proof:
      | { mode: "none" }
      | { mode: "image"; src: string; alt: string; caption?: string }
  }
  /** Marquee tape items. Empty array hides the ticker. */
  ticker: string[]
  benefits: { title: string; body: string; caption: string }[]
  howItWorks?: {
    heading: string
    steps: { title: string; body: string }[]
  }
  stats: {
    value: number
    decimals?: number
    prefix?: string
    suffix?: string
    label: string
  }[]
  /** Logos + testimonials. Both empty → section hidden. Fill with REAL proof. */
  socialProof: {
    heading?: string
    logos: { name: string; href?: string }[]
    testimonials: { quote: string; name: string; role?: string }[]
  }
  pricing?: {
    heading: string
    subhead?: string
    plans: {
      name: string
      price: string
      cadence?: string
      description?: string
      features: string[]
      cta: Cta
      featured?: boolean
      badge?: string
    }[]
    footnote?: string
  }
  faq?: {
    heading: string
    items: { q: string; a: string }[]
  }
  finalCta: {
    eyebrow?: string
    headline: string
    cta: Cta
    caption?: string
  }
  footer: {
    /** Legal / support links. Wire real hrefs per project. */
    links: { label: string; href: string }[]
    /** Small mono stamp on the right (e.g. a version marker). */
    note?: string
  }
}

