  return (
    <footer className="border-t border-[var(--border-1)] py-8">
      {/* Dot-matrix separator */}
      <div aria-hidden="true" className="dot-grid-subtle mb-6 h-6 w-full" />

      {/* Single mono footer row, uppercase, ghosted */}
      <div className="flex flex-wrap items-center justify-between gap-x-6 gap-y-4 font-mono text-[10px] tracking-[0.1em] text-[var(--fg-3)] uppercase">
        <span>
          (c) {new Date().getFullYear()} · {{ app_title }}
        </span>

        <span className="flex items-center gap-3">
          {footer.links.map((link, i) => (
            <span key={link.label} className="flex items-center gap-3">
              {i > 0 && <span aria-hidden>·</span>}
              <a href={link.href} className="hover:text-[var(--fg-1)]">
                {link.label}
              </a>
            </span>
          ))}
        </span>

        <span className="flex items-center gap-4">
          {footer.note && <span>{footer.note}</span>}
          <ThemeToggle />
        </span>
      </div>
    </footer>
