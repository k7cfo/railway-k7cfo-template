NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/{{ project_slug | replace('-', '_') }}
BETTER_AUTH_SECRET=development-only-change-this-secret-32-chars
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:5173
# Optional additional exact origins, comma-separated (for example a private Tailscale HTTPS URL)
TRUSTED_ORIGINS=
# Railway overwrites X-Real-IP. Change this only to a header your deployment proxy overwrites.
AUTH_IP_HEADER=x-real-ip
REGISTRATION_MODE=open

# Optional Tailscale tooling. Leave blank to discover this machine's MagicDNS name automatically.
TAILSCALE_URL=
TAILSCALE_TARGET=

# Optional AI: mock | openai | anthropic
AI_PROVIDER={{ default_ai_provider }}
AI_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional email: console | resend
EMAIL_PROVIDER=console
EMAIL_FROM={{ app_title }} <hello@example.com>
RESEND_API_KEY=

# Optional object storage: local | s3 | r2
STORAGE_PROVIDER=local
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Optional billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
