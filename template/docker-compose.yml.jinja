services:
  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_DB: {{ project_slug | replace('-', '_') }}
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{ project_slug | replace('-', '_') }}"]
      interval: 2s
      timeout: 3s
      retries: 20
volumes:
  postgres_data:
